# GitHub personal access token, public_repo scope only.
# Used server-side by Octokit. Never expose to the client.
GITHUB_TOKEN=ghp_xxx

# Anthropic API key — only needed if the LLM summary feature is enabled.
# The summary is an optional extra (M3); the dashboard works without it.
ANTHROPIC_API_KEY=sk-ant-xxx

# Vercel KV (Upstash Redis under the hood). Required for analysis caching.
KV_REST_API_URL=https://example.upstash.io
KV_REST_API_TOKEN=

# Public-facing app URL, used for share links and OG metadata.
NEXT_PUBLIC_APP_URL=http://localhost:3000
